# =============================================================================
# HOMEPEDIA — .env.prod UNIQUE (racine). Une seule source pour TOUTE la prod :
# la stack VPS (serving + Airflow) ET la VM GCP (Spark) lisent ce fichier.
#   cp .env.prod.example .env.prod   # remplir ; NE JAMAIS committer .env.prod
#
# Les deux compose y pointent en relatif (env_file: ../../../../.env.prod). Une
# variable non utilisée par un service est simplement ignorée — c'est voulu :
# on tolère un sur-ensemble pour n'avoir qu'un fichier.
# =============================================================================

# ─── Commun (VPS + VM) ───────────────────────────────────────────────────────
# = ghcr.io/<owner>/<repo> en MINUSCULES. La CI pousse les images sous
# <IMAGE_REGISTRY>/homepedia-<api|frontend|spark|airflow>. Ne PAS ajouter
# de segment /homepedia à la fin.
IMAGE_REGISTRY=ghcr.io/epitechmscpropromo2026/t-dat-902-par_5
IMAGE_TAG=latest

# Base Gold PostgreSQL — creds partagés. POSTGRES_HOST = IP publique du VPS :
# c'est la VM GCP (Spark) qui l'utilise pour écrire le Gold via JDBC. Côté VPS,
# l'API ignore POSTGRES_HOST/DATABASE_URL (le compose lui impose `postgres:5432`).
POSTGRES_USER=homepedia
POSTGRES_PASSWORD=CHANGE_ME_strong
POSTGRES_DB=homepedia_gold
POSTGRES_HOST=91.134.132.149
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://homepedia:CHANGE_ME_strong@91.134.132.149:5432/homepedia_gold
# Port Gold publié sur le VPS (à filtrer au pare-feu vers l'IP de la VM GCP).
POSTGRES_PUBLIC_PORT=5432

# AWS S3 (Bronze/Silver) — ingestion Airflow (VPS) + lecture Spark (VM).
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=eu-north-1
S3_ENDPOINT_URL=                           # vide = vrai AWS S3
S3_BRONZE_BUCKET=homepedia-bronze
S3_SILVER_BUCKET=homepedia-silver
S3_GOLD_BUCKET=homepedia-gold

# ─── VPS — reverse-proxy, API, frontend ──────────────────────────────────────
# Sans nom de domaine payant : nip.io mappe une IP -> un hostname (ex.
# 91.134.132.149.nip.io) et Caddy obtient un vrai cert Let's Encrypt dessus.
# Remplacer <VPS_IP> par l'IP publique du VPS (ex. 91-134-132-149 accepté aussi).
APP_DOMAIN=<VPS_IP>.nip.io
API_DOMAIN=api.<VPS_IP>.nip.io
AIRFLOW_DOMAIN=airflow.<VPS_IP>.nip.io
AIRFLOW_BASE_URL=https://airflow.<VPS_IP>.nip.io
CADDY_EMAIL=ton.email@epitech.eu           # enregistrement Let's Encrypt
GOLD_SCHEMA=market
WEB_CONCURRENCY=4
# Origine du frontend (appels API côté navigateur : search, fiche commune…).
# Doit matcher APP_DOMAIN en https.
API_CORS_ORIGINS=https://<VPS_IP>.nip.io
LOG_LEVEL=INFO
# Frontend (Auth.js + Prisma/SQLite). openssl rand -base64 33
AUTH_SECRET=CHANGE_ME_base64_secret
SEED_ON_START=0                            # 1 au 1er boot (admin démo), puis 0

# ─── Airflow (metadata + admin) ──────────────────────────────────────────────
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGE_ME
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_fernet
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_WEB_PORT=8080

# ─── VM GCP Spark (démarrée/arrêtée par Airflow) ─────────────────────────────
GCP_PROJECT=project-fb866fa9-d405-4e5e-92c
GCP_ZONE=us-central1-c
GCP_INSTANCE=instance-20260704-224836
SPARK_SSH_USER=semakia_djaba_epitech_eu
SPARK_SSH_HOST=35.254.120.223
# Défaut de repli ; les DAGs surchargent spark.driver.memory par job (VM 8 Go).
SPARK_DRIVER_MEMORY=5g
